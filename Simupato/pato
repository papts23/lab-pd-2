public abstract class Pato {

    protected Cuaqueable cuaqueble;
    protected Volable volar;

    public Pato(Cuaqueable cuaqueble, Volable volar) {
        this.cuaqueble = cuaqueble;
        this.volar = volar;
    }

    public void setCuaqueble(Cuaqueable cuaqueble) {
        this.cuaqueble = cuaqueble;
    }

    public void setVolar(Volable volar) {
        this.volar = volar;
    }

    public abstract void mostrar();

    public void realizarCuaqueo() {
        cuaqueble.cuaquear();
    }
    
    public void realizarVuelo(){
        cuaqueble.cuaquear();
    }
    public void nadar(){
        System.out.println("Todos los Patos nadan");
    }
}
